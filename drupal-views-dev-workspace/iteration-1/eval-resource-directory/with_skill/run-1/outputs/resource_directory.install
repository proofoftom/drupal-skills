<?php

/**
 * @file
 * Install, update, and uninstall functions for the resource_directory module.
 */

/**
 * Implements hook_schema().
 */
function resource_directory_schema() {
  $schema['resource_links'] = [
    'description' => 'Stores resource directory entries.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'not null' => TRUE,
        'description' => 'Primary key.',
      ],
      'title' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'The resource title.',
      ],
      'url' => [
        'type' => 'varchar',
        'length' => 2048,
        'not null' => TRUE,
        'default' => '',
        'description' => 'The resource URL.',
      ],
      'category' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
        'description' => 'The resource category.',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when the resource was created.',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'category' => ['category'],
    ],
  ];

  return $schema;
}
