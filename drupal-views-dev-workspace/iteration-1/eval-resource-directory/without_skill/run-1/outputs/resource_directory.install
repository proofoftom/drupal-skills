<?php

/**
 * @file
 * Install, update, and uninstall functions for the Resource Directory module.
 */

/**
 * Implements hook_schema().
 */
function resource_directory_schema(): array {
  $schema['resource_links'] = [
    'description' => 'Stores resource links for the resource directory.',
    'fields' => [
      'id' => [
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'title' => [
        'description' => 'The resource title.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
      ],
      'url' => [
        'description' => 'The resource URL.',
        'type' => 'varchar',
        'length' => 2048,
        'not null' => TRUE,
        'default' => '',
      ],
      'category' => [
        'description' => 'The resource category.',
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
      ],
      'created' => [
        'description' => 'Unix timestamp when the resource was created.',
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'category' => ['category'],
    ],
  ];

  return $schema;
}
