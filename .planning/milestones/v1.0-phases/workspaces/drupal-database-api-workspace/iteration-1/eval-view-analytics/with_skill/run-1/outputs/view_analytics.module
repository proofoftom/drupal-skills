<?php

/**
 * @file
 * Hooks for the View Analytics module.
 */

use Drupal\node\NodeInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;

/**
 * Implements hook_node_view().
 */
function view_analytics_node_view(array &$build, NodeInterface $node, EntityViewDisplayInterface $display, string $view_mode): void {
  if ($view_mode !== 'full') {
    return;
  }

  /** @var \Drupal\view_analytics\ViewAnalyticsTracker $tracker */
  $tracker = \Drupal::service('view_analytics.tracker');
  $tracker->recordView((int) $node->id(), (int) \Drupal::currentUser()->id());
}
