<?php

/**
 * @file
 * Install, update and uninstall functions for the content_indexer module.
 */

/**
 * Implements hook_schema().
 */
function content_indexer_schema(): array {
  $schema['content_indexer_status'] = [
    'description' => 'Tracks the indexing state of content nodes.',
    'fields' => [
      'nid' => [
        'description' => 'The node ID.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'indexed' => [
        'description' => 'Whether the node has been indexed (0=no, 1=yes).',
        'type' => 'int',
        'size' => 'tiny',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'indexed_at' => [
        'description' => 'Unix timestamp when the node was last indexed.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => FALSE,
        'default' => NULL,
      ],
    ],
    'primary key' => ['nid'],
  ];

  return $schema;
}
