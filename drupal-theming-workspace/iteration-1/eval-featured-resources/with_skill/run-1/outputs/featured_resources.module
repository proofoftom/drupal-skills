<?php

/**
 * @file
 * Featured Resources module hooks.
 */

/**
 * Implements hook_theme().
 */
function featured_resources_theme($existing, $type, $theme, $path): array {
  return [
    'featured_resources_list' => [
      'variables' => [
        'items' => [],
        'heading' => NULL,
      ],
    ],
  ];
}

/**
 * Prepares variables for featured_resources_list templates.
 *
 * Default template: featured-resources-list.html.twig.
 */
function template_preprocess_featured_resources_list(array &$variables): void {
  $variables['attributes']['class'][] = 'featured-resources';
}
