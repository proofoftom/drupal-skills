<?php

/**
 * @file
 * Install, update and uninstall functions for the view_analytics module.
 */

/**
 * Implements hook_schema().
 */
function view_analytics_schema(): array {
  $schema['view_analytics'] = [
    'description' => 'Stores content view tracking data.',
    'fields' => [
      'id' => [
        'description' => 'Primary key.',
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
      ],
      'nid' => [
        'description' => 'Node ID of the viewed content.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'uid' => [
        'description' => 'User ID of the viewer (0 = anonymous).',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'viewed_at' => [
        'description' => 'Unix timestamp of when the view occurred.',
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
      ],
      'referrer' => [
        'description' => 'HTTP referrer URL.',
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'default' => '',
      ],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'nid' => ['nid'],
      'uid' => ['uid'],
      'viewed_at' => ['viewed_at'],
    ],
  ];

  return $schema;
}
