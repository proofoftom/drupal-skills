<?php

/**
 * @file
 * Tracks content views in a custom database table.
 */

use Drupal\node\NodeInterface;

/**
 * Records a content view to the tracking table.
 *
 * @param int $nid
 *   The node ID being viewed.
 * @param int $uid
 *   The user ID of the viewer (0 for anonymous).
 * @param string $referrer
 *   The HTTP referrer URL, truncated to 255 characters.
 */
function view_analytics_record_view(int $nid, int $uid, string $referrer = ''): void {
  \Drupal::database()->insert('view_analytics')
    ->fields([
      'nid' => $nid,
      'uid' => $uid,
      'viewed_at' => \Drupal::time()->getRequestTime(),
      'referrer' => mb_substr($referrer, 0, 255),
    ])
    ->execute();
}

/**
 * Implements hook_node_view().
 */
function view_analytics_node_view(array &$build, NodeInterface $node, $display, string $view_mode): void {
  if ($view_mode !== 'full') {
    return;
  }

  $request = \Drupal::request();
  view_analytics_record_view(
    (int) $node->id(),
    (int) \Drupal::currentUser()->id(),
    (string) $request->headers->get('referer', ''),
  );
}
